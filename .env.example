# Environment Variables for Production
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control!

# Vercel Environment Variables (set in Vercel Dashboard instead)
# Go to: Project Settings > Environment Variables
# Add these variables in Vercel:

# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
# NEXT_PUBLIC_APP_NAME=Sistem Manajemen Denah Ujian

# Note: This app uses localStorage for data persistence
# No API keys or secrets needed for basic functionality

# If you add backend/API later, use this format:
# DATABASE_URL=your_database_url
# API_SECRET_KEY=your_secret_key
